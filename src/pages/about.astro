---
import Layout from '../layouts/Layout.astro';
---

<Layout title="À propos — Mat.enseigne">

  <!-- ══ HERO ══ -->
  <section class="ab-hero">
    <div class="ab-hero__bg" aria-hidden="true"></div>
    <div class="ab-hero__wrap">
      <p class="ab-hero__eyebrow">
        <span class="ab-hero__dot"></span>Notre histoire
      </p>
      <h1 class="ab-hero__title">
        Faire briller<br/>
        <em>votre commerce</em>,<br/>
        c'est notre métier.
      </h1>
      <p class="ab-hero__sub">
        Depuis 2008, nous concevons, fabriquons et posons des enseignes
        qui transforment des vitrines ordinaires en points d'attraction.
      </p>
    </div>
    <div class="ab-hero__scroll" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ══ STORY ══ -->
  <section class="ab-story">
    <div class="ab-story__wrap">

      <div class="ab-story__text">
        <p class="ab-tag">Qui sommes-nous</p>
        <h2 class="ab-title">Artisans de l'enseigne<br/>depuis plus de 15 ans</h2>
        <p class="ab-body">
          Mat.enseigne est née d'une conviction simple : une enseigne bien faite,
          c'est le premier acte marketing d'un commerce. Avant le site web,
          avant les réseaux sociaux — c'est la façade qui parle.
        </p>
        <p class="ab-body">
          On travaille avec tout le monde — le kebab du coin qui veut enfin être
          repéré de loin, le salon de coiffure qui cherche quelque chose d'élégant,
          la pharmacie qui veut moderniser son image. Du projet au lendemain de la pose,
          vous avez toujours quelqu'un au bout du fil.
        </p>
        <div class="ab-story__badges">
          <span class="ab-badge">Paris & IDF</span>
          <span class="ab-badge">Devis gratuit</span>
          <span class="ab-badge">Pose incluse</span>
        </div>
      </div>

      <div class="ab-story__visual">
        <div class="ab-story__card ab-story__card--1">
          <span class="ab-story__year">2008</span>
          <span class="ab-story__year-label">Fondation</span>
        </div>
        <div class="ab-story__stat-stack">
          <div class="ab-story__stat">
            <span class="ab-story__num">15<sup>+</sup></span>
            <span class="ab-story__lbl">ans d'expérience</span>
          </div>
          <div class="ab-story__stat">
            <span class="ab-story__num">1000<sup>+</sup></span>
            <span class="ab-story__lbl">commerces habillés</span>
          </div>
          <div class="ab-story__stat">
            <span class="ab-story__num">24h</span>
            <span class="ab-story__lbl">7j/7 disponibles</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ VALUES ══ -->
  <section class="ab-values">
    <div class="ab-values__wrap">

      <div class="ab-values__header">
        <p class="ab-tag">Notre approche</p>
        <h2 class="ab-title">Ce qui nous distingue</h2>
      </div>

      <div class="ab-values__grid">

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Qualité fabrication</h3>
          <p class="ab-value__body">
            Chaque enseigne sort de notre atelier. Matériaux premium,
            finitions soignées — on ne sous-traite pas ce qui compte.
          </p>
        </div>

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Rapidité d'exécution</h3>
          <p class="ab-value__body">
            De la validation du devis à la pose : 2 à 3 semaines en moyenne.
            Pour les urgences, on s'adapte — appelez-nous directement.
          </p>
        </div>

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Proximité client</h3>
          <p class="ab-value__body">
            On se déplace, on écoute, on conseille. Pas de call center —
            vous parlez directement avec l'équipe qui fait le travail.
          </p>
        </div>

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Couverture IDF</h3>
          <p class="ab-value__body">
            Paris et toute l'Île-de-France. On se déplace partout pour le devis
            et la pose — sans frais cachés, sans mauvaise surprise.
          </p>
        </div>

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Conception graphique</h3>
          <p class="ab-value__body">
            Pas d'idée précise ? Notre équipe propose des visuels adaptés à votre
            commerce, votre budget et votre identité.
          </p>
        </div>

        <div class="ab-value">
          <div class="ab-value__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"/>
              <path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c1.51 0 2.93.37 4.18 1.03"/>
              <path d="M21 3v4h-4"/>
            </svg>
          </div>
          <h3 class="ab-value__title">Suivi garanti</h3>
          <p class="ab-value__body">
            Après la pose, on reste disponibles. Retouche, problème électrique,
            extension — on revient sans hésiter.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="icta">
    <div class="icta__bg" aria-hidden="true"></div>
    <div class="icta__wrap">
      <div class="icta__left">
        <p class="icta__label">Commençons ensemble</p>
        <h2 class="icta__title">
          Votre projet mérite<br/>un vrai échange.
        </h2>
        <p class="icta__body">
          On se déplace gratuitement, on écoute votre projet, on vous propose
          une solution adaptée à votre budget — sans engagement.
        </p>
      </div>
      <div class="icta__right">
        <a href="tel:+33605894411" class="icta__btn icta__btn--primary">
          ☎&nbsp; 06 05 89 44 11
        </a>
        <a href="/contact" class="icta__btn icta__btn--ghost">
          Envoyer un message
        </a>
        <p class="icta__trust">Devis gratuit · Réponse sous 24h</p>
      </div>
    </div>
  </section>

</Layout>


<style>
  /* ── Shared ── */
  .ab-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--gold);
    margin-bottom: 0.85rem;
  }
  .ab-tag--light { color: rgba(255,255,255,0.5); }

  .ab-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .ab-title--light { color: white; }

  .ab-body {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .ab-body--light { color: rgba(255,255,255,0.6); }

  /* ── Hero ── */
  .ab-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--nav-h);
  }

  .ab-hero__bg {
    position: absolute;
    inset: 0;
    background: #31559F;
  }
  .ab-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(0,180,245,0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 10% 80%, rgba(255,184,0,0.07) 0%, transparent 50%);
  }

  .ab-hero__wrap {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 3rem 5rem;
  }

  .ab-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 1.5rem;
  }

  .ab-hero__dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--warm-gold);
    flex-shrink: 0;
  }

  .ab-hero__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }
  .ab-hero__title em {
    font-style: normal;
    color: var(--warm-gold);
  }

  .ab-hero__sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    max-width: 520px;
    line-height: 1.75;
  }

  .ab-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .ab-hero__scroll span {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
    margin: 0 auto;
    animation: scrollLine 1.8s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50%  { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ── Story ── */
  .ab-story {
    padding: 6rem 2rem;
    background: var(--bg);
  }

  .ab-story__wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .ab-story__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.75rem;
  }

  .ab-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--navy);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 0.35rem 0.9rem;
    border-radius: 20px;
  }

  .ab-story__visual {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ab-story__card {
    background: linear-gradient(135deg, #0E1B30, #31559F);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ab-story__year {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 4rem;
    font-weight: 800;
    color: white;
    line-height: 1;
  }

  .ab-story__year-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.4);
  }

  .ab-story__stat-stack {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
  }

  .ab-story__stat {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
  }

  .ab-story__num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
  }
  .ab-story__num sup {
    font-size: 1rem;
    color: var(--warm-gold);
  }

  .ab-story__lbl {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--muted);
    text-align: center;
    line-height: 1.3;
  }

  /* ── Values ── */
  .ab-values {
    padding: 6rem 2rem;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .ab-values__wrap {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ab-values__header {
    margin-bottom: 3.5rem;
  }

  .ab-values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ab-value {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 1.75rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .ab-value:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.09);
    transform: translateY(-3px);
  }

  .ab-value__icon {
    width: 52px; height: 52px;
    border-radius: 12px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    margin-bottom: 1.25rem;
    transition: background 0.2s, color 0.2s;
  }
  .ab-value:hover .ab-value__icon {
    background: var(--navy);
    color: white;
    border-color: var(--navy);
  }

  .ab-value__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.65rem;
  }

  .ab-value__body {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ── Zone ── */
  .ab-zone {
    background: linear-gradient(135deg, #0E1B30 0%, #31559F 100%);
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .ab-zone::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 90% 10%, rgba(0,180,245,0.15) 0%, transparent 55%);
  }

  .ab-zone__wrap {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .ab-zone__depts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .ab-zone__dept {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.65);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    transition: background 0.2s, color 0.2s;
  }
  .ab-zone__dept:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  .ab-zone__cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-shrink: 0;
  }

  .ab-zone__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    background: var(--warm-gold);
    color: #0E1B30;
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    transition: all 0.2s;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(255,184,0,0.3);
  }
  .ab-zone__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255,184,0,0.45);
  }

  .ab-zone__phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .ab-zone__phone:hover {
    color: white;
    border-color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.08);
  }

  /* ── CTA ── */
  .icta {
    position: relative;
    background: #31559F;
    padding: 5.5rem 2rem;
    overflow: hidden;
  }
  .icta__bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(0,158,224,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .icta__wrap {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }
  .icta__label {
    font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: rgba(238,236,234,0.45); margin-bottom: 0.75rem;
  }
  .icta__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2.3rem);
    font-weight: 800; color: white; line-height: 1.25; margin-bottom: 1rem;
  }
  .icta__body {
    font-size: 0.9rem; color: rgba(238,236,234,0.55);
    line-height: 1.7; max-width: 440px;
  }
  .icta__right {
    display: flex; flex-direction: column;
    gap: 0.85rem; min-width: 210px;
  }
  .icta__btn {
    display: flex; align-items: center; justify-content: center;
    gap: 0.5rem; font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem; font-weight: 600;
    padding: 0.85rem 1.5rem; border-radius: 8px;
    text-align: center; transition: all 0.2s; cursor: pointer; border: none;
  }
  .icta__btn--primary {
    background: var(--warm-gold); color: var(--navy);
    box-shadow: 0 4px 24px rgba(255,184,0,0.35);
  }
  .icta__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(255,184,0,0.45); }
  .icta__btn--ghost {
    background: transparent; color: rgba(238,236,234,0.7);
    border: 1px solid rgba(238,236,234,0.2);
  }
  .icta__btn--ghost:hover { background: rgba(255,255,255,0.08); color: white; border-color: rgba(255,255,255,0.4); }
  .icta__trust { font-size: 0.72rem; color: rgba(238,236,234,0.3); text-align: center; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .ab-hero__wrap { padding: 4rem 1.5rem 4rem; }
    .ab-hero { min-height: 60vh; }

    .ab-story { padding: 4rem 1.5rem; }
    .ab-story__wrap { grid-template-columns: 1fr; gap: 3rem; }
    .ab-story__stat-stack { grid-template-columns: repeat(3, 1fr); }
    .ab-story__stat { padding: 1rem 0.5rem; }
    .ab-story__num { font-size: 1.5rem; }

    .ab-values { padding: 4rem 1.5rem; }
    .ab-values__grid { grid-template-columns: 1fr; gap: 1rem; }

    .ab-zone { padding: 4rem 1.5rem; }
    .ab-zone__wrap { grid-template-columns: 1fr; gap: 2.5rem; }
    .ab-zone__cta { flex-direction: column; }

    .icta { padding: 4rem 1.5rem; }
    .icta__wrap { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
    .icta__body { max-width: none; }
    .icta__right { min-width: 0; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .ab-values__grid { grid-template-columns: repeat(2, 1fr); }
    .ab-story__wrap { gap: 3rem; }
  }
</style>
