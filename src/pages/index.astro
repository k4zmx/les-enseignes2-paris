---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mat.enseigne — Enseignes & Façades Paris">

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section class="hero">

    <!-- Full-bleed background image -->
    <img src="/herobg.png" alt="" class="hero__bg" aria-hidden="true" />

    <!-- Dark gradient overlay -->
    <div class="hero__overlay" aria-hidden="true"></div>

    <!-- Content -->
    <div class="hero__content">

      <!-- Eyebrow -->
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-dot"></span>
        Fabrication &amp; installation · Paris &amp; Île-de-France
      </p>

      <!-- Main title -->
      <h1 class="hero__title">
        Une vitrine négligée, c'est un client<br/>
        qui passe <em>sans s'arrêter</em>
      </h1>

      <!-- Subtitle -->
      <p class="hero__sub">
        Depuis 2008, nous fabriquons et posons des enseignes pour tous types de commerces
        — du kebab au salon de coiffure, en passant par les boutiques de luxe.
      </p>

      <!-- CTA buttons -->
      <div class="hero__actions">
        <a href="tel:+33605894411" class="hero__btn hero__btn--primary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07
              19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11
              2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45
              2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45
              c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Appeler maintenant
        </a>
        <a href="/services" class="hero__btn hero__btn--ghost">
          Nos réalisations
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Stats row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">15+</span>
          <span class="hero__stat-label">ans d'expérience</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-num">1000+</span>
          <span class="hero__stat-label">commerces habillés</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-num">24h / 7j</span>
          <span class="hero__stat-label">disponible</span>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="hero__scroll" aria-hidden="true">
        <span class="hero__scroll-label">Découvrir</span>
        <div class="hero__scroll-line"></div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TRUST BAR
  ══════════════════════════════════════════ -->
  <div class="trust-bar">
    <div class="trust-bar__track">
      <div class="trust-bar__reel">
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Fabrication locale — atelier en IDF
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Pose incluse, aucun sous-traitant
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Devis gratuit sous 24h
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Tous types de commerces
        </div>
        <span class="trust-bar__sep"></span>
        <!-- duplicate for seamless loop -->
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Fabrication locale — atelier en IDF
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Pose incluse, aucun sous-traitant
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Devis gratuit sous 24h
        </div>
        <span class="trust-bar__sep"></span>
        <div class="trust-bar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Tous types de commerces
        </div>
        <span class="trust-bar__sep"></span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       BEFORE / AFTER
  ══════════════════════════════════════════ -->
  <section class="ba">
    <div class="ba__header reveal">
      <p class="ba__eyebrow"><span class="ba__eyebrow-dot"></span>Nos transformations</p>
      <h2 class="ba__title">Avant <span class="ba__title-accent">&amp;</span> Après</h2>
      <p class="ba__sub">La différence que nous faisons — en images.</p>
    </div>

    <div class="ba__grid">

      <!-- Pair 1 — drag slider -->
      <div class="bslider reveal">
        <div class="bslider__layer bslider__layer--after">
          <img src="/after.jpeg" alt="Après" />
          <span class="bslider__tag bslider__tag--after">Après</span>
        </div>
        <div class="bslider__layer bslider__layer--before">
          <img src="/before.jpeg" alt="Avant" />
          <span class="bslider__tag">Avant</span>
        </div>
        <div class="bslider__handle">
          <div class="bslider__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="var(--gold)" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
              <polyline points="9 18 3 12 9 6" transform="rotate(180,12,12)"/>
            </svg>
          </div>
        </div>
        <p class="bslider__hint">Glissez pour comparer</p>
      </div>

      <!-- Pair 2 — drag slider -->
      <div class="bslider reveal">
        <div class="bslider__layer bslider__layer--after">
          <img src="/after1.png" alt="Après 2" />
          <span class="bslider__tag bslider__tag--after">Après</span>
        </div>
        <div class="bslider__layer bslider__layer--before">
          <img src="/before1.png" alt="Avant 2" />
          <span class="bslider__tag">Avant</span>
        </div>
        <div class="bslider__handle">
          <div class="bslider__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="var(--gold)" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
              <polyline points="9 18 3 12 9 6" transform="rotate(180,12,12)"/>
            </svg>
          </div>
        </div>
        <p class="bslider__hint">Glissez pour comparer</p>
      </div>

      <!-- Pair 3 — drag slider -->
      <div class="bslider reveal">
        <div class="bslider__layer bslider__layer--after">
          <img src="/after2.png" alt="Après 3" />
          <span class="bslider__tag bslider__tag--after">Après</span>
        </div>
        <div class="bslider__layer bslider__layer--before">
          <img src="/before2.png" alt="Avant 3" />
          <span class="bslider__tag">Avant</span>
        </div>
        <div class="bslider__handle">
          <div class="bslider__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="var(--gold)" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
              <polyline points="9 18 3 12 9 6" transform="rotate(180,12,12)"/>
            </svg>
          </div>
        </div>
        <p class="bslider__hint">Glissez pour comparer</p>
      </div>

    </div>

    <p class="ba__quote reveal">
      "Une vitrine soignée, c'est un client qui s'arrête."
    </p>

    <div class="ba__cta-wrap reveal">
      <a href="/creations" class="ba__cta-btn">
        <span>Voir toutes nos réalisations</span>
        <svg class="ba__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SERVICES
  ══════════════════════════════════════════ -->
  <section class="services" id="services">
    <div class="services__wrap">

      <div class="services__header reveal">
        <p class="svc-label">
          <span class="svc-label-line"></span>
          Nos services
          <span class="svc-label-line"></span>
        </p>
        <h2 class="svc-title">Ce que nous fabriquons pour vous</h2>
      </div>

      <!-- ── ROW 1: text left · image right ── -->
      <div class="svc-row">
        <div class="svc-row__text fade-up delay-1">
          <span class="svc-row__ghost">01</span>
          <p class="svc-row__label"><span class="svc-row__dot"></span>Enseigne</p>
          <h3 class="svc-row__heading">Enseignes lumineuses &amp; drapeaux</h3>
          <p class="svc-row__desc">
            Des enseignes LED, caissons lumineux et drapeaux publicitaires qui
            attirent l'œil de jour comme de nuit — fabriqués sur mesure dans notre atelier.
          </p>
          <ul class="svc-row__details">
            <li>Enseignes LED basse consommation</li>
            <li>Caissons lumineux rétroéclairés</li>
            <li>Enseignes drapeaux et oriflammes</li>
            <li>Maintenance et dépannage inclus</li>
          </ul>
        </div>
        <div class="svc-row__img slide-from-right">
          <div class="svc-carousel" data-carousel>
            <div class="svc-carousel__track">
              <img src="/abtus.jpeg" alt="Enseignes lumineuses 1" class="svc-carousel__slide" />
              <img src="/cat2.jpeg" alt="Enseignes lumineuses 2" class="svc-carousel__slide" />
              <img src="/cat21.jpeg" alt="Enseignes lumineuses 3" class="svc-carousel__slide" />
            </div>
            <button class="svc-carousel__btn svc-carousel__btn--prev" aria-label="Précédent">&#8249;</button>
            <button class="svc-carousel__btn svc-carousel__btn--next" aria-label="Suivant">&#8250;</button>
            <div class="svc-carousel__dots">
              <span class="svc-carousel__dot active"></span>
              <span class="svc-carousel__dot"></span>
              <span class="svc-carousel__dot"></span>
            </div>
          </div>
          <div class="svc-row__overlay"></div>
          <div class="svc-row__corner svc-row__corner--tl">
            <span class="svc-row__corner-h"></span>
            <span class="svc-row__corner-v"></span>
          </div>
        </div>
      </div>

      <!-- ── ROW 2: image left · text right ── -->
      <div class="svc-row">
        <div class="svc-row__img slide-from-left">
          <div class="svc-carousel" data-carousel>
            <div class="svc-carousel__track">
              <img src="/drap1.jpeg" alt="Service 2 photo 1" class="svc-carousel__slide active" />
              <img src="/drap2.jpeg" alt="Service 2 photo 2" class="svc-carousel__slide" />
              <img src="/drap3.jpeg" alt="Service 2 photo 3" class="svc-carousel__slide" />
            </div>
            <button class="svc-carousel__btn svc-carousel__btn--prev" aria-label="Précédent">&#8249;</button>
            <button class="svc-carousel__btn svc-carousel__btn--next" aria-label="Suivant">&#8250;</button>
            <div class="svc-carousel__dots">
              <span class="svc-carousel__dot active"></span>
              <span class="svc-carousel__dot"></span>
              <span class="svc-carousel__dot"></span>
            </div>
          </div>
          <div class="svc-row__overlay"></div>
          <div class="svc-row__corner svc-row__corner--tl">
            <span class="svc-row__corner-h"></span>
            <span class="svc-row__corner-v"></span>
          </div>
        </div>
        <div class="svc-row__text fade-up delay-1">
          <span class="svc-row__ghost">02</span>
          <p class="svc-row__label"><span class="svc-row__dot"></span>Store</p>
          <h3 class="svc-row__heading">Stores bannes sur mesure</h3>
          <p class="svc-row__desc">
            Motorisés ou manuels, nos stores bannes protègent votre vitrine tout en
            affirmant l'identité de votre commerce.
          </p>
          <ul class="svc-row__details">
            <li>Stores bannes motorisés</li>
            <li>Marquage et impression sur toile</li>
            <li>Marquises et auvents</li>
            <li>Entretien et remplacement de toile</li>
          </ul>
        </div>
      </div>

      <!-- ── ROW 3: text left · image right ── -->
      <div class="svc-row">
        <div class="svc-row__text fade-up delay-1">
          <span class="svc-row__ghost">03</span>
          <p class="svc-row__label"><span class="svc-row__dot"></span>Marquage</p>
          <h3 class="svc-row__heading">Marquage adhésif</h3>
          <p class="svc-row__desc">
            Vitrines, véhicules, panneaux publicitaires — le marquage adhésif haute
            qualité qui fait parler de vous partout où vous allez.
          </p>
          <ul class="svc-row__details">
            <li>Covering et lettrage véhicules</li>
            <li>Vitrophanie et décoration vitrine</li>
            <li>Panneaux et supports publicitaires</li>
            <li>Découpe numérique sur mesure</li>
          </ul>
        </div>
        <div class="svc-row__img slide-from-right">
          <div class="svc-carousel" data-carousel>
            <div class="svc-carousel__track">
              <img src="/marq1.jpeg" alt="Service 3 photo 1" class="svc-carousel__slide active" />
              <img src="/marq2.jpeg" alt="Service 3 photo 2" class="svc-carousel__slide" />
              <img src="/marq3.jpeg" alt="Service 3 photo 3" class="svc-carousel__slide" />
              <img src="/cat23.jpeg" alt="Service 3 photo 4" class="svc-carousel__slide" />
            </div>
            <button class="svc-carousel__btn svc-carousel__btn--prev" aria-label="Précédent">&#8249;</button>
            <button class="svc-carousel__btn svc-carousel__btn--next" aria-label="Suivant">&#8250;</button>
            <div class="svc-carousel__dots">
              <span class="svc-carousel__dot active"></span>
              <span class="svc-carousel__dot"></span>
              <span class="svc-carousel__dot"></span>
              <span class="svc-carousel__dot"></span>
            </div>
          </div>
          <div class="svc-row__overlay"></div>
          <div class="svc-row__corner svc-row__corner--tl">
            <span class="svc-row__corner-h"></span>
            <span class="svc-row__corner-v"></span>
          </div>
        </div>
      </div>

      <!-- ── ROW 4: image left · text right ── -->
      <div class="svc-row svc-row--last">
        <div class="svc-row__img slide-from-left">
          <div class="svc-carousel" data-carousel>
            <div class="svc-carousel__track">
              <img src="/cat1.jpeg"  alt="Création sur mesure 1" class="svc-carousel__slide" />
              <img src="/cat41.png"  alt="Création sur mesure 2" class="svc-carousel__slide" />
              <img src="/cat42.png"  alt="Création sur mesure 3" class="svc-carousel__slide" />
            </div>
            <button class="svc-carousel__btn svc-carousel__btn--prev" aria-label="Précédent">&#8249;</button>
            <button class="svc-carousel__btn svc-carousel__btn--next" aria-label="Suivant">&#8250;</button>
            <div class="svc-carousel__dots">
              <span class="svc-carousel__dot active"></span>
              <span class="svc-carousel__dot"></span>
              <span class="svc-carousel__dot"></span>
            </div>
          </div>
          <div class="svc-row__overlay"></div>
          <div class="svc-row__corner svc-row__corner--tl">
            <span class="svc-row__corner-h"></span>
            <span class="svc-row__corner-v"></span>
          </div>
        </div>
        <div class="svc-row__text fade-up delay-1">
          <span class="svc-row__ghost">04</span>
          <p class="svc-row__label"><span class="svc-row__dot"></span>Sur mesure</p>
          <h3 class="svc-row__heading">Création &amp; pose sur mesure</h3>
          <p class="svc-row__desc">
            De la conception à la pose, nous gérons l'intégralité de votre projet —
            un seul interlocuteur, de la conception à la livraison.
          </p>
          <ul class="svc-row__details">
            <li>Conception graphique incluse</li>
            <li>Fabrication en atelier propre</li>
            <li>Pose par notre équipe qualifiée</li>
            <li>Accompagnement administratif</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════
       GOOGLE REVIEWS
  ══════════════════════════════════════════ -->
  <section class="reviews">
    <div class="reviews__wrap">
      <div class="reviews__header reveal">
        <div class="reviews__google-badge">
          <svg class="reviews__google-icon" width="22" height="22" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span class="reviews__google-text">Google Reviews</span>
        </div>
        <p class="reviews__label">
          <span class="reviews__label-line"></span>
          Avis clients
          <span class="reviews__label-line"></span>
        </p>
        <h2 class="reviews__title">Ce que nos clients disent de nous</h2>
        <div class="reviews__summary">
          <span class="reviews__avg">4.5</span>
          <div class="reviews__avg-stars">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24"><defs><linearGradient id="hstar"><stop offset="50%" stop-color="#FBBC05"/><stop offset="50%" stop-color="#D1D5DB"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z" fill="url(#hstar)"/></svg>
          </div>
          <span class="reviews__count">basé sur 87 avis</span>
        </div>
      </div>

      <div class="reviews__slider" data-rv-slider>
        <button class="reviews__arrow reviews__arrow--prev" aria-label="Avis précédent">&#8249;</button>

        <div class="reviews__track">

          <!-- 1 — 5 stars -->
          <div class="rv-card">
            <div class="rv-card__head">
              <div class="rv-card__avatar">K</div>
              <div>
                <p class="rv-card__name">Karim B.</p>
                <p class="rv-card__date">Il y a 2 semaines</p>
              </div>
            </div>
            <div class="rv-card__stars">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
