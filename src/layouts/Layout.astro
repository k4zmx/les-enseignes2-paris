---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg:           #FFFFFF;
        --bg-card:      #FFFFFF;
        --bg-soft:      #EEF5FC;
        --text:         #1A2A4A;
        --muted:        #5E7099;
        --border:       #C5D6EE;
        --border-glow:  rgba(0, 158, 224, 0.4);
        --gold:         #009EE0;
        --gold-bright:  #00B4F5;
        --gold-soft:    rgba(0, 158, 224, 0.09);
        --glow-sm:      0 0 14px rgba(0, 158, 224, 0.35);
        --glow-md:      0 0 28px rgba(0, 158, 224, 0.28), 0 0 60px rgba(0, 158, 224, 0.1);
        --warm-gold:    #FFB800;
        --nav-h:        72px;
        --navy:         #31559F;
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }

      img    { display: block; max-width: 100%; }
      a      { text-decoration: none; color: inherit; }
      button { font-family: inherit; cursor: pointer; }
    </style>
  </head>

  <body>

    <!-- ── NAVBAR ─────────────────────────────── -->
    <header id="navbar">
      <div class="nav__wrap">

        <a href="/" class="nav__logo" aria-label="Mat.enseigne — Accueil">
          <svg width="136" height="32" viewBox="0 0 136 32" xmlns="http://www.w3.org/2000/svg">
            <polygon points="0,28 4,28 4,5 0,0"     fill="#009EE0"/>
            <polygon points="4,5 10,15 7,15 2,5"    fill="#009EE0" opacity="0.7"/>
            <polygon points="10,15 16,5 19,5 13,15" fill="#009EE0" opacity="0.7"/>
            <polygon points="16,5 20,0 20,28 16,28" fill="#009EE0"/>
            <line x1="0" y1="31" x2="20" y2="31" stroke="#009EE0" stroke-width="1" opacity="0.4"/>
            <line x1="27" y1="4" x2="27" y2="27"  stroke="#009EE0" stroke-width="0.8" opacity="0.25"/>
            <text x="33" y="22"
              font-family="'DM Sans', sans-serif" font-weight="700"
              font-size="16" fill="white" letter-spacing="-0.4">mat</text>
            <text x="59" y="22"
              font-family="'DM Sans', sans-serif" font-weight="700"
              font-size="16" fill="#009EE0">.</text>
            <text x="64" y="22"
              font-family="'DM Sans', sans-serif" font-weight="400"
              font-size="13.5" fill="#009EE0" letter-spacing="0.4">enseigne</text>
          </svg>
        </a>

        <nav class="nav__links" aria-label="Navigation principale">
          <a href="/"           class="nav__link">Accueil</a>
          <a href="/creations"  class="nav__link">Nos créations</a>
          <a href="/about"      class="nav__link">À propos</a>
          <a href="/contact"    class="nav__link">Contact</a>
        </nav>

        <div class="nav__actions">
          <a href="tel:+33605894411" class="nav__phone">06 05 89 44 11</a>

          <a
            href="https://www.instagram.com/mat.enseigne"
            target="_blank"
            rel="noopener noreferrer"
            class="nav__insta"
            aria-label="Instagram Mat.enseigne"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>

          <a href="/contact" class="nav__cta">Nous contacter</a>

          <a
            href="https://www.instagram.com/mat.enseigne"
            target="_blank"
            rel="noopener noreferrer"
            class="nav__insta nav__insta--mobile"
            aria-label="Instagram Mat.enseigne"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>

          <button class="nav__burger" id="burger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>

      </div>
    </header>

    <!-- ── MOBILE MENU ────────────────────────── -->
    <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
      <nav>
        <a href="/">Accueil</a>
        <a href="/creations">Nos créations</a>
        <a href="/about">À propos</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>

    <!-- ── STICKY CALL BUTTON (mobile only) ──── -->
    <a href="tel:+33605894411" class="sticky-call" aria-label="Appeler maintenant">
      <span class="sticky-call__dot"></span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.2"
        stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l.83-.83a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="sticky-call__text">
        <span class="sticky-call__label">Appelez maintenant</span>
        <span class="sticky-call__number">06 05 89 44 11</span>
      </span>
    </a>

    <!-- ── PAGE CONTENT ───────────────────────── -->
    <slot />

    <!-- ── FOOTER ─────────────────────────────── -->
    <footer class="footer" id="contact">
      <div class="footer__wrap">

        <div class="footer__brand">
          <svg width="120" height="28" viewBox="0 0 136 32" xmlns="http://www.w3.org/2000/svg">
            <polygon points="0,28 4,28 4,5 0,0"     fill="#00B4F5"/>
            <polygon points="4,5 10,15 7,15 2,5"    fill="#00B4F5" opacity="0.7"/>
            <polygon points="10,15 16,5 19,5 13,15" fill="#00B4F5" opacity="0.7"/>
            <polygon points="16,5 20,0 20,28 16,28" fill="#00B4F5"/>
            <line x1="0" y1="31" x2="20" y2="31" stroke="#00B4F5" stroke-width="1" opacity="0.4"/>
            <line x1="27" y1="4" x2="27" y2="27"  stroke="#00B4F5" stroke-width="0.8" opacity="0.25"/>
            <text x="33" y="22"
              font-family="'DM Sans', sans-serif" font-weight="700"
              font-size="16" fill="rgba(238,236,234,0.85)" letter-spacing="-0.4">mat</text>
            <text x="59" y="22"
              font-family="'DM Sans', sans-serif" font-weight="700"
              font-size="16" fill="#00B4F5">.</text>
            <text x="64" y="22"
              font-family="'DM Sans', sans-serif" font-weight="400"
              font-size="13.5" fill="#00B4F5" letter-spacing="0.4">enseigne</text>
          </svg>
          <p class="footer__tagline">
            Fabrication & pose d'enseignes<br/>
            Paris & Île-de-France depuis 2008
          </p>
          <a
            href="https://www.instagram.com/mat.enseigne"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__insta"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            @mat.enseigne
          </a>
        </div>

        <div class="footer__col">
          <p class="footer__col-title">Services</p>
          <a href="#services">Enseignes lumineuses</a>
          <a href="#services">Façades & Habillage</a>
          <a href="#services">Lettres & Signalétique</a>
          <a href="#services">Stores & Marquises</a>
        </div>

        <div class="footer__col">
          <p class="footer__col-title">Contact</p>
          <a href="tel:+33605894411">06 05 89 44 11</a>
          <a href="mailto:contact@matenseigne.fr">contact@matenseigne.fr</a>
          <p class="footer__zone">Paris & Île-de-France</p>
          <p class="footer__zone">Lun – Sam · Devis gratuit</p>
        </div>

      </div>

      <div class="footer__bottom">
        <p>© 2025 Mat.enseigne — Tous droits réservés</p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ─────────────────────────────────────────────
     NAVBAR
  ───────────────────────────────────────────── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    height: var(--nav-h);
    background: transparent;
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  #navbar.scrolled {
    background: rgba(49, 85, 159, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 158, 224, 0.15);
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.2);
  }

  .nav__wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .nav__logo { flex-shrink: 0; display: block; }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav__link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: white;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--gold); }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav__phone {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: white;
    opacity: 0.8;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .nav__phone:hover { opacity: 1; }

  .nav__insta {
    display: flex;
    align-items: center;
    color: white;
    transition: color 0.2s;
  }
  .nav__insta:hover { color: var(--gold); }

  .nav__cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    background: var(--warm-gold) !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--navy);
    background: var(--gold);
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .nav__cta:hover {
    background: white;
    color: var(--navy);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    padding: 4px;
  }
  .nav__burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: white;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s;
  }
  .nav__burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav__burger.open span:nth-child(2) { opacity: 0; }
  .nav__burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    z-index: 49;
    background: rgba(49, 85, 159, 0.98);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .mobile-nav.open { opacity: 1; pointer-events: auto; }

  .mobile-nav nav { display: flex; flex-direction: column; }
  .mobile-nav a {
    display: block;
    padding: 0.9rem 1.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: white;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: color 0.15s;
  }
  .mobile-nav a:last-child { border-bottom: none; }
  .mobile-nav a:hover { color: var(--gold); }
  .mobile-nav__cta {
    color: var(--gold) !important;
    font-weight: 600 !important;
  }

  /* Mobile Instagram icon — hidden on desktop (desktop already has one in nav__actions) */
  .nav__insta--mobile { display: none; }

  @media (max-width: 768px) {
    .nav__links          { display: none; }
    .nav__phone          { display: none; }
    .nav__insta:not(.nav__insta--mobile) { display: none; }
    .nav__insta--mobile  { display: flex; }
    .nav__cta            { display: none; }
    .nav__burger         { display: flex; }
    .mobile-nav          { display: block; }
    .nav__wrap           { padding: 0 1.25rem; }
  }

  /* ── Sticky call button (mobile only) ── */
  .sticky-call {
    display: none;
  }

  @media (max-width: 768px) {
    .sticky-call {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      position: fixed;
      bottom: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 100;
      background: #0E1B30;
      color: white;
      padding: 0.75rem 1.4rem;
      border-radius: 50px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,184,0,0.18);
      text-decoration: none;
      white-space: nowrap;
    }

    .sticky-call__dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22C55E;
      flex-shrink: 0;
      box-shadow: 0 0 0 2px rgba(34,197,94,0.3);
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 2px rgba(34,197,94,0.3); }
      50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
    }

    .sticky-call svg {
      flex-shrink: 0;
      color: var(--warm-gold);
    }

    .sticky-call__text {
      display: flex;
      flex-direction: column;
      line-height: 1.2;
    }

    .sticky-call__label {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
    }

    .sticky-call__number {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      color: white;
    }

    /* Inverted state when over dark sections */
    .sticky-call.inverted {
      background: #EEF5FC;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15), 0 0 0 1px rgba(49,85,159,0.12);
    }
    .sticky-call.inverted .sticky-call__label { color: rgba(26,26,46,0.5); }
    .sticky-call.inverted .sticky-call__number { color: var(--navy); }
    .sticky-call.inverted svg { color: var(--navy); }
  }

  /* ─────────────────────────────────────────────
     FOOTER  (stays dark — contrast anchor)
  ───────────────────────────────────────────── */
  .footer {
    background: #31559F;
    color: rgba(238, 236, 234, 0.4);
    font-size: 0.85rem;
    border-top: 1px solid rgba(0, 180, 245, 0.12);
  }

  .footer__wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4.5rem 2rem 3.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .footer__tagline {
    margin-top: 1.1rem;
    font-size: 0.8rem;
    line-height: 1.75;
    color: rgba(238, 236, 234, 0.3);
  }

  .footer__insta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.1rem;
    font-size: 0.8rem;
    color: #00B4F5;
    transition: opacity 0.15s;
  }
  .footer__insta:hover { opacity: 0.75; }

  .footer__col { display: flex; flex-direction: column; gap: 0.55rem; }
  .footer__col-title {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(238, 236, 234, 0.2);
    margin-bottom: 0.5rem;
  }
  .footer__col a {
    font-size: 0.84rem;
    color: rgba(238, 236, 234, 0.4);
    transition: color 0.15s;
  }
  .footer__col a:hover { color: var(--warm-gold); }
  .footer__zone { font-size: 0.78rem; color: rgba(238, 236, 234, 0.2); margin-top: 0.15rem; }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.25rem 2rem;
    text-align: center;
    font-size: 0.72rem;
    color: rgba(238, 236, 234, 0.18);
  }

  @media (max-width: 768px) {
    .footer__wrap {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 1.5rem 2.5rem;
    }
  }
</style>

<script>
  /* ── Navbar scroll state ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }, { passive: true });

  /* ── Mobile menu ── */
  const burger    = document.getElementById('burger');
  const mobileNav = document.getElementById('mobile-nav');

  burger?.addEventListener('click', () => {
    const open = burger.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
    mobileNav?.classList.toggle('open', open);
    mobileNav?.setAttribute('aria-hidden', String(!open));
  });

  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      mobileNav.classList.remove('open');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });

  /* ── Sticky call button: invert over dark sections ── */
  const stickyCall = document.querySelector('.sticky-call');
  if (stickyCall) {
    const darkSections = document.querySelectorAll('.icta, .footer');
    let darkCount = 0;

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        darkCount += e.isIntersecting ? 1 : -1;
      });
      stickyCall.classList.toggle('inverted', darkCount > 0);
    }, { threshold: 0.05 });

    darkSections.forEach(el => obs.observe(el));
  }
</script>
